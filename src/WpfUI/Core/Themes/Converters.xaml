<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:core="clr-namespace:WpfUI.Core.Base">

  <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
  <core:BoolToVisibilityConverter x:Key="InverseBoolToVis" IsInverse="True"/>
  <core:ResourceKeyToGeometryConverter x:Key="ResourceKeyToGeometryConverter"/>

  <core:DepthToMarginConverter x:Key="DepthToMarginConverter" IndentSize="16"/>

  <core:GridLengthConverter x:Key="GridLengthConverter"/>
</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="BgBaseColor">#0F111A</Color>
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource BgBaseColor}"/>

  <SolidColorBrush x:Key="GlassBorderBrush" Color="#33FFFFFF"/>
  <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
  <SolidColorBrush x:Key="SecondaryTextBrush" Color="#94A3B8"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#6366F1"/>
  <SolidColorBrush x:Key="FrostWhite">#E2E8F0</SolidColorBrush>
  <SolidColorBrush x:Key="CyberCyan">#0ea5e9</SolidColorBrush>
  <SolidColorBrush x:Key="ElectricSlate">#00ADB5</SolidColorBrush>

  <LinearGradientBrush x:Key="GlassBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#1AFFFFFF" Offset="0"/>
    <GradientStop Color="#08FFFFFF" Offset="1"/>
  </LinearGradientBrush>

  <DropShadowEffect x:Key="LiteShadow" 
                      BlurRadius="10" 
                      ShadowDepth="1" 
                      Opacity="0.2" 
                      Color="Black"
                      RenderingBias="Performance"/>
  <Style x:Key="NavNavigationButtonStyle" TargetType="RadioButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Height" Value="45"/>
    <Setter Property="Margin" Value="0,2"/>
    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="RootBorder" Background="{TemplateBinding Background}" CornerRadius="6">
            <ContentPresenter VerticalAlignment="Center" Margin="0,0"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="RootBorder" Property="Background" Value="#12FFFFFF"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ExplorerPanelBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="#1C1F2E"/>
    <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,1,0"/>
    <Setter Property="Width" Value="280"/>
    <!-- Setter Property="RenderTransform">
      <TranslateTransform X="0"/>
    </Setter -->
  </Style>

  <Style x:Key="ExplorerHeaderStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    <Setter Property="FontSize" Value="18"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="20,24,20,16"/>
  </Style>


  <SolidColorBrush x:Key="ModernAccentBlueBrush" Color="#007ACC"/>
  <SolidColorBrush x:Key="ModernSplitterNormalBrush" Color="#33FFFFFF"/>

  <!-- Main View Splitter -->
  <Style x:Key="ModernGridSplitterStyle" TargetType="GridSplitter">
    <Setter Property="Height" Value="8"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="ShowsPreview" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GridSplitter">
          <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Border x:Name="SplitterLine"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Height="2"
                                Background="{StaticResource ModernSplitterNormalBrush}"
                                CornerRadius="1"
                                Opacity="0.6"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="SplitterLine" Property="Height" Value="4" />
              <Setter TargetName="SplitterLine" Property="Opacity" Value="1.0" />
              <Setter TargetName="SplitterLine" Property="Background" Value="{StaticResource ModernAccentBlueBrush}" />
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
              <Setter TargetName="SplitterLine" Property="Height" Value="4" />
              <Setter TargetName="SplitterLine" Property="Opacity" Value="1.0" />
              <Setter TargetName="SplitterLine" Property="Background" Value="{StaticResource ModernAccentBlueBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>

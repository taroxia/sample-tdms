<core:ViewBase x:TypeArguments="local:SkeletonExpViewModel"
               x:Class="WpfUI.Features.Skeleton.Explorer.SkeletonExpView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
               xmlns:local="clr-namespace:WpfUI.Features.Skeleton.Explorer"
               xmlns:core="clr-namespace:WpfUI.Core.Base"
               mc:Ignorable="d" 
               d:DesignHeight="450" d:DesignWidth="250">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Assets/Icons.xaml"/>
        <ResourceDictionary Source="../Assets/Icons.Explorer.xaml"/>
        <ResourceDictionary Source="../Assets/Styles.xaml"/>
        <ResourceDictionary Source="../Assets/Styles.Explorer.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Background="{StaticResource PrimaryDarkBrush}">
    <StackPanel Margin="10">
      <TextBlock Text="Metadata Explorer" Foreground="{StaticResource TextLightBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
      <Border Style="{StaticResource ExplorerCardStyle}" Padding="8">
        <StackPanel>
          <TextBlock Text="Available Nodes" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,6"/>
          <ListBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextLightBrush}"
                   ItemsSource="{Binding AvailableNodes}"
                   SelectedItem="{Binding SelectedNode.Value, Mode=TwoWay}">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <EventSetter Event="MouseMove" Handler="Node_MouseMove"/>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</core:ViewBase>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1E1E24" />
  <SolidColorBrush x:Key="AccentBadgeBrush" Color="#2A2D34" />
  <SolidColorBrush x:Key="TextLightBrush" Color="#F5F5F6" />
  <SolidColorBrush x:Key="BorderDropZoneBrush" Color="#4A90E2" />

  <Style x:Key="ModernBadgeStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource AccentBadgeBrush}"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="Margin" Value="4"/>
  </Style>
</ResourceDictionary>

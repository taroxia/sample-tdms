<!-- File: WpfUI/Features/Skeleton/Documents/SkeletonDocView.xaml -->
<core:ViewBase x:TypeArguments="local:SkeletonDocViewModel"
               x:Class="WpfUI.Features.Skeleton.Documents.SkeletonDocView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:local="clr-namespace:WpfUI.Features.Skeleton.Documents"
               xmlns:explorer="clr-namespace:WpfUI.Features.Skeleton.Documents.Explorer"
               xmlns:charts="clr-namespace:WpfUI.Features.Skeleton.Documents.Charts"
               xmlns:details="clr-namespace:WpfUI.Features.Skeleton.Documents.Details"
               xmlns:core="clr-namespace:WpfUI.Core.Base">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Assets/Icons.Documents.xaml"/>
        <ResourceDictionary Source="../Assets/Styles.Documents.xaml"/>
        <ResourceDictionary Source="/Core/Themes/Styles.xaml"/>
        <ResourceDictionary Source="/Core/Themes/Converters.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <DataTemplate DataType="{x:Type explorer:SkeletonDocExpViewModel}">
        <explorer:SkeletonDocExpView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type charts:SkeletonDocChartViewModel}">
        <charts:SkeletonDocChartView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type details:SkeletonDocDetailViewModel}">
        <details:SkeletonDocDetailView />
      </DataTemplate>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Background="#0F111A">
    <Grid.ColumnDefinitions>
      <!-- マルチバインディングによって、開閉状態とリサイズ値を安全に調停 -->
      <ColumnDefinition x:Name="ExplorerColumn">
        <ColumnDefinition.Width>
          <MultiBinding Converter="{StaticResource GridLengthConverter}" Mode="TwoWay">
            <Binding Path="IsExplorerExpanded.Value" Mode="OneWay"/>
            <Binding Path="ExplorerWidth.Value" Mode="TwoWay"/>
          </MultiBinding>
        </ColumnDefinition.Width>
      </ColumnDefinition>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Explorer部 (Collapsed 時は入力を完全に遮断) -->
    <ContentControl Grid.Column="0" 
                    Content="{Binding ExplorerViewModel}"
                    Focusable="False"
                    Visibility="{Binding IsExplorerExpanded.Value, Converter={StaticResource BoolToVis}}"/>

    <!-- 垂直リサイザースプリッター -->
    <GridSplitter Grid.Column="1" 
                  Width="4" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Stretch"
                  Background="#26293B" 
                  ShowsPreview="True"
                  Visibility="{Binding IsExplorerExpanded.Value, Converter={StaticResource BoolToVis}}"/>

    <!-- フローティングトグルボタン -->
    <Button Grid.Column="1" 
            Panel.ZIndex="10"
            Style="{StaticResource FloatingToggleButtonStyle}"
            Command="{Binding ToggleExplorerCommand}"
            VerticalAlignment="Center" 
            HorizontalAlignment="Left"
            Margin="0,0,0,0">
      <Grid>
        <!-- 開閉状態で矢印の向きを切り替え -->
        <Path x:Name="ToggleArrow" 
              Data="{StaticResource IconChevronLeftGeometry}" 
              Fill="White" 
              Width="6" Height="10" 
              Stretch="Uniform">
          <Path.Style>
            <Style TargetType="Path">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsExplorerExpanded.Value}" Value="False">
                  <Setter Property="Data" Value="{StaticResource IconChevronRightGeometry}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Path.Style>
        </Path>
      </Grid>
    </Button>

    <!-- 右側メインコンテンツ -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="200"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*" MinHeight="200"/>
      </Grid.RowDefinitions>

      <ContentControl Grid.Row="0" Content="{Binding ChartViewModel}"/>

      <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                    Background="#26293B" ShowsPreview="True"/>

      <ContentControl Grid.Row="2" Content="{Binding DetailViewModel}"/>
    </Grid>
  </Grid>
</core:ViewBase>

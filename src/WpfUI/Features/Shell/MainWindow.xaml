<Window x:Class="WpfUI.Features.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:WpfUI.Core.Base"
        Title="TDMS Analyzer Pro" Height="700" Width="1100"
        Background="#F3F3F3" UseLayoutRounding="True">

    <Window.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter x:Key="InverseBoolToVis" IsInverse="True"/>
        <core:ResourceKeyToGeometryConverter x:Key="ResourceKeyToGeometryConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar" Background="#202020" Width="250">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="SidebarStates">
                    <VisualState x:Name="Expanded"/>
                    <VisualState x:Name="Collapsed">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="Sidebar" 
                                             Storyboard.TargetProperty="Width" 
                                             To="60" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/> <RowDefinition Height="*"/>  <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                <Button Grid.Row="2" Command="{Binding ToggleSidebarCommand}" Background="Transparent" BorderThickness="0" Height="50">
                    <Path x:Name="ToggleIcon" Fill="Gray" Width="16" Height="16" Stretch="Uniform"
                          Data="{StaticResource Icon.ChevronLeft}"/>
                </Button>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Navigation.Items}" Margin="12,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Style="{StaticResource NavNavigationButtonStyle}"
                                             IsChecked="{Binding IsActive.Value, Mode=TwoWay}"
                                             Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                             CommandParameter="{Binding}"
                                             ToolTip="{Binding Title}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{Binding IconKey, Converter={StaticResource ResourceKeyToGeometryConverter}}"
                                              Fill="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(TextElement.Foreground)}"
                                              Stretch="Uniform"
                                              Width="18" Height="18"
                                              Margin="0,0,12,0"
                                              SnapsToDevicePixels="True"/>
                                        
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Visibility="{Binding Navigation.IsSidebarExpanded.Value, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                <!-- StackPanel Grid.Row="1" Margin="8,10">
                    <Button Command="{Binding NavigateDashboardCommand}" Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDashboard}" Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                            <TextBlock Text="Dashboard" Margin="20,0,0,0" Foreground="White" VerticalAlignment="Center"
                                       Visibility="{Binding NavigationService.IsSidebarExpanded.Value, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <Button.ToolTip>
                            <ToolTip Content="Dashboard" Visibility="{Binding NavigationService.IsSidebarExpanded.Value, Converter={StaticResource InverseBoolToVis}}"/>
                        </Button.ToolTip>
                    </Button>

                    <Button Command="{Binding NavigateSettingsCommand}" Style="{StaticResource MenuButtonStyle}" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSettings}" Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                            <TextBlock Text="Settings" Margin="20,0,0,0" Foreground="White" VerticalAlignment="Center"
                                       Visibility="{Binding NavigationService.IsSidebarExpanded.Value, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <Button.ToolTip>
                            <ToolTip Content="Settings" Visibility="{Binding NavigationService.IsSidebarExpanded.Value, Converter={StaticResource InverseBoolToVis}}"/>
                        </Button.ToolTip>
                    </Button>
                </StackPanel -->

            </Grid>
        </Border>


            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding CurrentViewTitle.Value}" Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" Margin="32,0" FontSize="24" FontWeight="Bold"/>

                <Border Grid.Row="1" Margin="32,0,32,32" 
                        Background="{StaticResource GlassBackgroundBrush}" 
                        BorderBrush="{StaticResource GlassBorderBrush}"
                        BorderThickness="1.2"
                        CornerRadius="16"
                        Effect="{StaticResource LiteShadow}">
                    <ContentControl Content="{Binding CurrentView.Value}" ClipToBounds="True"/>
                </Border>
            </Grid>
    </Grid>
</Window>

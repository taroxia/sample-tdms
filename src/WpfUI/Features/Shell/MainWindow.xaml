<Window x:Class="WpfUI.Features.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        xmlns:core="clr-namespace:WpfUI.Core.Base"
        mc:Ignorable="d"
        Title="TDMS Analyzer Pro" Height="750" Width="1200"
        Background="{StaticResource AppBackgroundBrush}" UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <core:DockTemplateSelector x:Key="DockTemplateSelector"/>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
      <ColumnDefinition x:Name="ExplorerColumn" Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border x:Name="Sidebar" Background="#161925" Width="200" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,1,0">
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="SidebarStates">
          <VisualState x:Name="Expanded">
            <Storyboard>
              <DoubleAnimation Storyboard.TargetName="Sidebar" 
                         Storyboard.TargetProperty="Width" 
                         To="200" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
              <DoubleAnimation Storyboard.TargetName="IconRotate" 
                         Storyboard.TargetProperty="Angle" 
                         To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </VisualState>

          <VisualState x:Name="Collapsed">
            <Storyboard>
              <DoubleAnimation Storyboard.TargetName="Sidebar" 
                         Storyboard.TargetProperty="Width" 
                         To="50" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
              <DoubleAnimation Storyboard.TargetName="IconRotate" 
                         Storyboard.TargetProperty="Angle" 
                         To="180" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="70"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Command="{Binding ToggleSidebarCommand}"
                Background="Transparent" BorderThickness="0" Height="60" Margin="5"
                Cursor="Hand"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
          <Grid Width="210">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="44"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Path x:Name="ToggleIcon"
                  Grid.Column="0" Fill="{StaticResource SecondaryTextBrush}" 
                  Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"
                  Data="{StaticResource Icon.ChevronLeft}" RenderTransformOrigin="0.5,0.5">
              <Path.RenderTransform>
                <RotateTransform x:Name="IconRotate" Angle="0"/>
              </Path.RenderTransform>
            </Path>
          </Grid>
        </Button>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Navigation.Items}" Margin="4,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <RadioButton Style="{StaticResource NavNavigationButtonStyle}"
                           IsChecked="{Binding IsActive.Value, Mode=OneWay}"
                           Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                           CommandParameter="{Binding}"
                           ToolTip="{Binding Title}">
                <Grid Width="190" HorizontalAlignment="Left" ClipToBounds="True">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Path Grid.Column="0"
                        Data="{Binding IconKey, Converter={StaticResource ResourceKeyToGeometryConverter}}"
                        Fill="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(TextElement.Foreground)}"
                        Stretch="Uniform"
                        Width="20" Height="20"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        SnapsToDevicePixels="True"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             FontSize="14"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"/>
                </Grid>
              </RadioButton>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <!-- [ Explorer ] -->
    <Border x:Name="ExplorerPanel" 
            Grid.Column="1"
            Style="{StaticResource ExplorerPanelBorderStyle}"
            Visibility="{Binding HasExplorer.Value, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="70"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" 
                       Text="Explorer"
                       Style="{StaticResource ExplorerHeaderStyle}"/>
        <ContentControl Grid.Row="1" 
                            Content="{Binding CurrentExplorerView.Value}"/>
      </Grid>
    </Border>

    <!-- [ Main View ] -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="70"/>
        <RowDefinition Height="*" MinHeight="150"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="*" MinHeight="150"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="XXX" Foreground="{StaticResource PrimaryTextBrush}" 
                   VerticalAlignment="Center" Margin="40,0" FontSize="28" FontWeight="Bold"/>

      <!-- xcad:DockingManager Grid.Row="1" Margin="32,0,32,0">
        <xcad:LayoutRoot>
          <xcad:LayoutPanel Orientation="Vertical">
            <xcad:LayoutAnchorablePane>
              <xcad:LayoutAnchorable Title="Document Control" CanClose="False" CanHide="True">
                <Border Background="{StaticResource GlassBackgroundBrush}" 
                                    BorderBrush="{StaticResource GlassBorderBrush}"
                                    BorderThickness="1">
                  <ContentControl Content="{Binding CurrentDocumentView.Value}" ClipToBounds="True"/>
                </Border>
              </xcad:LayoutAnchorable>
            </xcad:LayoutAnchorablePane>
          </xcad:LayoutPanel>
        </xcad:LayoutRoot>
      </xcad:DockingManager -->

      <!--xcad:DockingManager  Grid.Row="1" Margin="32,0,32,0"
                                 DocumentsSource="{Binding Navigation.Documents}"
                                 LayoutItemTemplateSelector="{StaticResource DockTemplateSelector}"
                                 LayoutItemContainerStyle="{StaticResource LayoutItemStyle}" -->
      <xcad:DockingManager Grid.Row="1" Margin="32,0,32,0"
                           DocumentsSource="{Binding Navigation.Documents}"
                           LayoutItemTemplateSelector="{StaticResource DockTemplateSelector}">
        <i:Interaction.Behaviors>
          <core:DockBridgeBehavior />
        </i:Interaction.Behaviors>

        <xcad:DockingManager.LayoutItemContainerStyle>
          <Style TargetType="{x:Type xcad:LayoutDocumentItem}">
            <Setter Property="Title" Value="{Binding Model.Title.Value, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding Model.IsSelected.Value, Mode=TwoWay}" />
            <Setter Property="IsActive" Value="{Binding Model.IsActive.Value, Mode=TwoWay}" />
          </Style>

        </xcad:DockingManager.LayoutItemContainerStyle>

        <xcad:LayoutRoot>
          <xcad:LayoutPanel Orientation="Horizontal">
            <xcad:LayoutDocumentPaneGroup>
              <!-- xcad:LayoutDocumentPane
                x:Name="MainDocumentPane"
                core:DockBridgeBehavior.PaneContextKey="{Binding Navigation.CurrentActiveViewModelType.Value, Mode=OneWay}"
                DockMinHeight="150"
                DockMinWidth="150"/ -->
              <!--xcad:LayoutDocumentPane
                x:Name="MainDocumentPane"
                core:DockBridgeBehavior.PaneContextKey="{Binding Navigation.SelectedItem.Value.ViewModelType, Mode=OneWay}">
              </xcad:LayoutDocumentPane -->
              
              <!-- xcad:LayoutDocumentPane
                x:Name="MainDocumentPane"
                core:DockBridgeBehavior.PaneContextKey="{Binding Navigation.CurrentNavigatorType}">
              </xcad:LayoutDocumentPane -->

              <xcad:LayoutDocumentPane
                x:Name="MainDocumentPane"
                DockMinHeight="150"
                DockMinWidth="150"/>
            </xcad:LayoutDocumentPaneGroup>
          </xcad:LayoutPanel>
        </xcad:LayoutRoot>

        <!-- xcad:LayoutRoot>
          <xcad:LayoutPanel Orientation="Vertical">
            <xcad:LayoutDocumentPaneGroup>
              <xcad:LayoutDocumentPane DockMinHeight="150" DockMinWidth="150"/>
            </xcad:LayoutDocumentPaneGroup>
          </xcad:LayoutPanel>
        </xcad:LayoutRoot -->
      </xcad:DockingManager>

      <!-- Splitter -->
      <GridSplitter Grid.Row="2" 
              Margin="32,0,32,0"
              Style="{StaticResource ModernGridSplitterStyle}"/>

      <!-- Right Bottom -->
      <Border Grid.Row="3" Margin="32,0,32,32" 
                    Background="{StaticResource GlassBackgroundBrush}" 
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Effect="{StaticResource LiteShadow}">
        <ContentControl Content="{Binding CurrentView.Value}" ClipToBounds="True"/>
      </Border>
    </Grid>

  </Grid>
</Window>

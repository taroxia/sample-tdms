<Window x:Class="WpfUI.Features.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title.Value}" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

  <Grid>
    <Rectangle HorizontalAlignment="Right" VerticalAlignment="Top" Width="500" Height="500" Margin="0,-150,-150,0">
      <Rectangle.Fill>
        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
          <GradientStop Color="#156366F1" Offset="0"/>
          <GradientStop Color="#006366F1" Offset="1"/>
        </RadialGradientBrush>
      </Rectangle.Fill>
    </Rectangle>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Background="#0AFFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,1,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="TDMS ANALYZER" Foreground="{StaticResource PrimaryTextBrush}" 
                               FontSize="16" FontWeight="Black" VerticalAlignment="Center" Margin="24,0"/>

          <ItemsControl Grid.Row="1" ItemsSource="{Binding Navigation.Items}" Margin="12,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <RadioButton Style="{StaticResource NavNavigationButtonStyle}"
                                             IsChecked="{Binding IsActive.Value, Mode=TwoWay}"
                                             Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                             CommandParameter="{Binding}">
                  <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"/>
                </RadioButton>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Grid.Row="2" Text="v1.0.0-release" Foreground="{StaticResource SecondaryTextBrush}" 
                               FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
        </Grid>
      </Border>

      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="70"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="XXXXX" Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" Margin="32,0" FontSize="24" FontWeight="Bold"/>

        <Border Grid.Row="1" Margin="32,0,32,32" 
                        Background="{StaticResource GlassBackgroundBrush}" 
                        BorderBrush="{StaticResource GlassBorderBrush}"
                        BorderThickness="1.2"
                        CornerRadius="16"
                        Effect="{StaticResource LiteShadow}">
          <ContentControl Content="{Binding CurrentView.Value}" ClipToBounds="True"/>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>

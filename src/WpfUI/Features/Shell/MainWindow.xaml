<Window x:Class="WpfUI.Features.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:WpfUI.Core.Base"
        Title="TDMS Analyzer Pro" Height="750" Width="1200"
        Background="{StaticResource AppBackgroundBrush}" UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
      <ColumnDefinition x:Name="ExplorerColumn" Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- [ Navigator ] -->
    <Border x:Name="Sidebar" Background="#161925" Width="200" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,1,0">
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="SidebarStates">
          <VisualState x:Name="Expanded"/>
          <VisualState x:Name="Collapsed">
            <Storyboard>
              <DoubleAnimation Storyboard.TargetName="Sidebar" 
                                             Storyboard.TargetProperty="Width" 
                                             To="50" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                  <QuadraticEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="70"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- [ Expand / Collapse Button ] -->
        <Button Grid.Row="0" Command="{Binding ToggleSidebarCommand}" 
                        Background="Transparent" BorderThickness="0" Height="60" Margin="8,0,8,12"
                        Cursor="Hand" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
          <Grid Width="210">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="44"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Path x:Name="ToggleIcon" Grid.Column="0" Fill="{StaticResource SecondaryTextBrush}" 
                              Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"
                              Data="{StaticResource Icon.ChevronLeft}">
              <Path.RenderTransform>
                <ScaleTransform ScaleX="1"/>
              </Path.RenderTransform>
            </Path>
          </Grid>
        </Button>


        <!-- [ Menu ] -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Navigation.Items}" Margin="4,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <RadioButton Style="{StaticResource NavNavigationButtonStyle}"
                                         IsChecked="{Binding IsActive.Value, Mode=OneWay}"
                                         Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                         CommandParameter="{Binding}"
                                         ToolTip="{Binding Title}">
                <Grid Width="180">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <Path Grid.Column="0" 
                                          Data="{Binding IconKey, Converter={StaticResource ResourceKeyToGeometryConverter}}"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(TextElement.Foreground)}"
                                          Stretch="Uniform"
                                          Width="20" Height="20"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          SnapsToDevicePixels="True"/>

                  <TextBlock Grid.Column="1" Text="{Binding Title}" 
                                               FontSize="14" Margin="12,0,0,0" 
                                               VerticalAlignment="Center"
                                               Visibility="{Binding DataContext.Navigation.IsSidebarExpanded.Value, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                </Grid>
              </RadioButton>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </Grid>
    </Border>

    <Border x:Name="ExplorerPanel" 
            Grid.Column="1"
            Style="{StaticResource ExplorerPanelBorderStyle}"
            Visibility="{Binding HasExplorer.Value, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="70"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                       Text="YYYS"
                       Style="{StaticResource ExplorerHeaderStyle}"/>

        <ContentControl Grid.Row="1" 
                            Content="{Binding CurrentExplorerView.Value}"/>
      </Grid>
    </Border>

    <!-- [ Main View ] -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="70"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="{Binding CurrentViewTitle.Value}" Foreground="{StaticResource PrimaryTextBrush}"
                       VerticalAlignment="Center" Margin="40,0" FontSize="28" FontWeight="Bold"/>

      <Border Grid.Row="1" Margin="32,0,32,32" 
                    Background="{StaticResource GlassBackgroundBrush}" 
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Effect="{StaticResource LiteShadow}">
        <ContentControl Content="{Binding CurrentView.Value}" ClipToBounds="True"/>
      </Border>
    </Grid>
  </Grid>
</Window>

<core:ViewBase x:TypeArguments="local:WaveformExpViewModel"
               x:Class="WpfUI.Features.Waveform.Explorer.WaveformExpView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:WpfUI.Features.Waveform.Explorer"
               xmlns:core="clr-namespace:WpfUI.Core.Base"
               mc:Ignorable="d"
               Background="Transparent">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Features/Waveform/Assets/Icons.Explorer.xaml" />
        <ResourceDictionary Source="/Features/Waveform/Assets/Styles.Explorer.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid AllowDrop="True">
    <i:Interaction.Triggers>
      <i:EventTrigger EventName="Drop">
        <i:InvokeCommandAction Command="{Binding DropFileCommand}" PassEventArgsToCommand="True"/>
      </i:EventTrigger>
    </i:Interaction.Triggers>

    <Border Style="{StaticResource GlassCard}" Margin="16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="16,16,16,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Path Data="{StaticResource Icon.FileTdms}" Fill="#0EA5E9" Stretch="Uniform" Width="18" Height="18"/>
            <TextBlock Text="TDMS DATA EXPLORER" Foreground="{StaticResource Brush.Text.Primary}" FontSize="12" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Grid.Column="1" Text="Arctic Slate Engine" Foreground="#66FFFFFF" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="16,4,16,12">
          <TextBox Text="{Binding SearchText.Value, UpdateSourceTrigger=PropertyChanged}" 
                   Style="{StaticResource ArcticSlateSearchBox}"
                   Tag="Search channels or groups..." Height="32" Padding="32,0,10,0"/>
          <Path Data="{StaticResource Icon.Search}" Fill="#55FFFFFF" Width="12" Height="12" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False" Stretch="Uniform"/>
        </Grid>

        <ListView Grid.Row="2" 
                  ItemsSource="{Binding FlattenedNodes}" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Margin="8,0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Focusable" Value="False"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListViewItem">
                    <ContentPresenter />
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListView.ItemContainerStyle>

          <ListView.Resources>
            <DataTemplate DataType="{x:Type local:FileNodeViewModel}">
              <Border Background="#334155" Opacity="0.4" CornerRadius="6" Margin="4,12,4,4" Padding="12,6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Path Data="{StaticResource Icon.FileTdms}" Fill="#0EA5E9" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource Brush.Text.Primary}" FontSize="12" FontWeight="SemiBold" ToolTip="{Binding FilePath}" VerticalAlignment="Center"/>
                  <Button Grid.Column="2" Style="{StaticResource FlatIconButton}" 
                          Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                          CommandParameter="{Binding}">
                    <Path Data="{StaticResource Icon.Delete}" Fill="#EF4444" Width="12" Height="12" Stretch="Uniform"/>
                  </Button>
                </Grid>
              </Border>
            </DataTemplate>

            <DataTemplate DataType="{x:Type local:GroupNodeViewModel}">
              <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="4,4,4,8" Padding="12">
                <StackPanel>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Path Data="{StaticResource Icon.Folder}" Fill="#EAA100" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" Foreground="{StaticResource Brush.Text.Primary}" FontSize="12" FontWeight="Medium"/>
                      <TextBlock Text="{Binding Info}" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <CheckBox Grid.Column="2" Style="{StaticResource ModernMicroCheckBox}" 
                              IsChecked="{Binding IsSelected.Value, Mode=OneWay}"
                              HorizontalAlignment="Stretch">
                      <i:Interaction.Triggers>
                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                          <i:InvokeCommandAction Command="{Binding DataContext.ToggleAllSelectCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                 PassEventArgsToCommand="True"/>
                        </i:EventTrigger>
                      </i:Interaction.Triggers>
                      <Grid HorizontalAlignment="Stretch">
                        <TextBlock Grid.Column="0" Text="Select All" Foreground="{StaticResource Brush.Text.Primary}" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                      </Grid>
                    </CheckBox>
                  </Grid>

                  <ItemsControl ItemsSource="{Binding Children}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="2" FirstColumn="0"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type local:ChannelNodeViewModel}">
                        <Grid Margin="2">
                          <Grid Background="Transparent" Cursor="Hand">
                            <CheckBox Style="{StaticResource ModernMicroCheckBox}" 
                                      IsChecked="{Binding IsSelected.Value, Mode=OneWay}"
                                      HorizontalAlignment="Stretch"
                                      IsHitTestVisible="True">
                              <i:Interaction.Triggers>                                
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                  <i:InvokeCommandAction Command="{Binding DataContext.ChannelMouseDownCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                                                        PassEventArgsToCommand="True"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseMove">
                                  <i:InvokeCommandAction Command="{Binding DataContext.ChannelMouseMoveCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        PassEventArgsToCommand="True"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                  <i:InvokeCommandAction Command="{Binding DataContext.ChannelMouseUpCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        PassEventArgsToCommand="True"/>
                                </i:EventTrigger>
                              </i:Interaction.Triggers>

                              <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*"/>
                                  <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource Brush.Text.Primary}" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                <Button Grid.Column="1" Style="{StaticResource FlatIconButton}" Margin="4,0,0,0"
                                        Command="{Binding DataContext.CopyPropertyCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                                        CommandParameter="{Binding}" ToolTip="{Binding Info}">
                                  <Path Data="{StaticResource Icon.Info}" Fill="{StaticResource Brush.Text.Secondary}" Width="11" Height="11" Stretch="Uniform"/>
                                </Button>
                              </Grid>
                            </CheckBox>
                          </Grid>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.Resources>
        </ListView>

        <Border IsHitTestVisible="False" Margin="16" Grid.Row="2" Visibility="{Binding IsEmpty.Value, Converter={StaticResource BoolToVis}}">
          <Grid>
            <Rectangle Stroke="#15FFFFFF" StrokeThickness="1.5" StrokeDashArray="3 3" RadiusX="8" RadiusY="8"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8">
              <Path Data="{StaticResource Icon.FileTdms}" Fill="#10FFFFFF" Stretch="Uniform" Width="40" Height="40" Margin="0,0,0,12"/>
              <TextBlock Text="DROP TDMS FILES HERE" Foreground="#25FFFFFF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="Supports ultra high-speed native streaming" Foreground="#0AFFFFFF" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</core:ViewBase>

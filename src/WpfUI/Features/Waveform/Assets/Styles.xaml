<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:WpfUI.Core.Base">

    <Color x:Key="BaseBackground">#1E2530</Color>
    <Color x:Key="ControlBackground">#262F3D</Color>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FrostWhite}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic, Microsoft JhengHei"/>
    </Style>

    <local:TupleConverter x:Key="TupleConverter"/>

</ResourceDictionary>

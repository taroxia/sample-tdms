<core:ViewBase x:TypeArguments="local:WaveformViewModel"
               x:Class="WpfUI.Features.Waveform.WaveformView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
               xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
               xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
               xmlns:local="clr-namespace:WpfUI.Features.Waveform"
               xmlns:core="clr-namespace:WpfUI.Core.Base"
               mc:Ignorable="d" 
               d:DesignHeight="720" d:DesignWidth="1080"
               Background="#1E2530">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Features/Waveform/Assets/Icons.xaml" />
        <ResourceDictionary Source="/Features/Waveform/Assets/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#262F3D" CornerRadius="6" Padding="12" Margin="0,0,0,12">
      <Grid>
        <TextBlock Text="WAVEFORM MULTI-STAGE MONITOR" Foreground="#E2E8F0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        <Button Content="+ Add New Plot Layer" 
                        Command="{Binding AddLayerCommand}" 
                        HorizontalAlignment="Right" 
                        Padding="16,6" 
                        Background="#0ea5e9" Foreground="White" BorderThickness="0" FontWeight="Bold">
          <Button.Resources>
            <Style TargetType="Button">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </Button.Resources>
        </Button>
      </Grid>
    </Border>

    <ItemsControl Grid.Row="1" ItemsSource="{Binding PlotLayers}">
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type local:PlotLayerModel}">
          <Grid Margin="0,0,0,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MinHeight="220">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Name="LeftDropZone" Background="#151C25" BorderBrush="#00ADB5" BorderThickness="1,1,0,1" CornerRadius="4,0,0,4" AllowDrop="True">
                <TextBlock Text="[ + Left Y ]" Foreground="#00ADB5" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
              </Border>

              <Border Grid.Column="1" Background="#262F3D" BorderBrush="#374151" BorderThickness="0,1">
                <Grid>
                  <scott:WpfPlot Name="PlotControl"/>

                  <Border VerticalAlignment="Bottom" Height="24" Background="#AA151C25" Name="XDropZone" AllowDrop="True">
                    <TextBlock Text="↓ Drop here to set Shared X-Axis" Foreground="#E2E8F0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </Grid>
              </Border>

              <Border Grid.Column="2" Name="RightDropZone" Background="#151C25" BorderBrush="#00ADB5" BorderThickness="0,1,1,1" CornerRadius="0,4,4,0" AllowDrop="True">
                <TextBlock Text="[ + Right Y ]" Foreground="#00ADB5" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
              </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="4,4,4,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <ItemsControl Grid.Column="0" ItemsSource="{Binding Assignments}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type local:PlotAssignment}">
                    <Border Background="#1E293B" CornerRadius="12" Margin="4,2" Padding="8,4" BorderBrush="#334155" BorderThickness="1">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Position}" Foreground="#0ea5e9" FontWeight="Bold" Margin="0,0,6,0" FontSize="10"/>
                        <TextBlock Text="{Binding Channel.Name}" Foreground="#E2E8F0" FontSize="11" MaxWidth="120" TextTrimming="CharacterEllipsis"/>

                        <Button Content="✕" Margin="6,0,0,0" Foreground="#EF4444" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveAssignmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource TupleConverter}">
                              <Binding Path="DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}"/>
                              <Binding/>
                            </MultiBinding>
                          </Button.CommandParameter>
                        </Button>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Button Grid.Column="1" Content="Remove Stage" 
                                    Command="{Binding DataContext.RemoveLayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" Foreground="#EF4444" BorderThickness="0" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Grid.Row="2" Background="#151C25" Padding="8" CornerRadius="4">
      <TextBlock Text="💡 Tip: Drag channels from Explorer pane and drop onto Left/Right boxes or the X-Axis panel." Foreground="#6B7280" FontSize="11" HorizontalAlignment="Center"/>
    </Border>
  </Grid>
</core:ViewBase>
